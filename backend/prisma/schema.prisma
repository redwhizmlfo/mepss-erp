generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  users     User[]

  @@map("roles")
}

model Employee {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName    String               @map("full_name") @db.VarChar(160)
  dni         String               @unique @db.VarChar(20)
  position    String               @db.VarChar(120)
  phone       String?              @db.VarChar(40)
  hireDate    DateTime             @map("hire_date") @db.Date
  dailyPay    Decimal              @default(0) @map("daily_pay") @db.Decimal(12, 2)
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  users       User[]
  sales       Sale[]
  attendance  EmployeeAttendance[]
  payroll     PayrollSlip[]
  losses      InventoryLoss[]

  @@map("empleados")
}

model User {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId             String              @map("role_id") @db.Uuid
  employeeId         String?             @map("employee_id") @db.Uuid
  username           String              @unique @db.VarChar(80)
  passwordHash       String              @map("password_hash")
  active             Boolean             @default(true)
  lastAccessAt       DateTime?           @map("last_access_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  role               Role                @relation(fields: [roleId], references: [id])
  employee           Employee?           @relation(fields: [employeeId], references: [id])
  permissions        UserPermission[]
  inventoryMovements InventoryMovement[]
  payrollCreated     PayrollSlip[]
  supplierOrders     SupplierOrder[]

  @@map("usuarios")
}

model UserPermission {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  moduleKey  String   @map("module_key") @db.VarChar(50)
  canView    Boolean  @default(false) @map("can_view")
  canCreate  Boolean  @default(false) @map("can_create")
  canEdit    Boolean  @default(false) @map("can_edit")
  canDelete  Boolean  @default(false) @map("can_delete")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@map("user_permissions")
}

model Category {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String             @unique @db.VarChar(120)
  slug               String             @unique @db.VarChar(140)
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  products           Product[]
  supplierCategories SupplierCategory[]
  losses             InventoryLoss[]

  @@map("categorias")
}

model Product {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId          String                @map("category_id") @db.Uuid
  name                String                @db.VarChar(180)
  slug                String                @unique @db.VarChar(220)
  brand               String?               @db.VarChar(120)
  modelCode           String?               @map("model_code") @db.VarChar(80)
  specs               String?               @db.VarChar(500)
  unitName            String                @map("unit_name") @db.VarChar(60)
  stock               Decimal               @default(0) @db.Decimal(12, 2)
  reservedQty         Decimal               @default(0) @map("reserved_qty") @db.Decimal(12, 2)
  minStock            Decimal               @default(0) @map("min_stock") @db.Decimal(12, 2)
  salePrice           Decimal               @default(0) @map("sale_price") @db.Decimal(12, 2)
  costPrice           Decimal               @default(0) @map("cost_price") @db.Decimal(12, 2)
  iconCode            String?               @map("icon_code") @db.VarChar(50)
  imageUrl            String?               @map("image_url")
  description         String?
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  category            Category              @relation(fields: [categoryId], references: [id])
  images              ProductImage[]
  saleDetails         SaleDetail[]
  losses              InventoryLoss[]
  inventoryMovements  InventoryMovement[]
  supplierOrderDetail SupplierOrderDetail[]

  @@map("productos")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(1) @map("sort_order") @db.SmallInt
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sortOrder])
  @@map("imagenes_producto")
}

model Supplier {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName       String             @map("business_name") @db.VarChar(180)
  ruc                String             @unique @db.VarChar(20)
  contactName        String?            @map("contact_name") @db.VarChar(140)
  phone              String?            @db.VarChar(40)
  email              String?            @db.VarChar(160)
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  supplierCategories SupplierCategory[]
  losses             InventoryLoss[]
  orders             SupplierOrder[]

  @@map("proveedores")
}

model SupplierCategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([supplierId, categoryId])
  @@map("proveedor_categoria")
}

model PaymentMethod {
  id     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code   String  @unique @db.VarChar(50)
  name   String  @db.VarChar(100)
  active Boolean @default(true)
  sales  Sale[]

  @@map("metodos_pago")
}

model VoucherType {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String  @unique @db.VarChar(50)
  name         String  @db.VarChar(100)
  seriesPrefix String? @map("series_prefix") @db.VarChar(20)
  active       Boolean @default(true)
  sales        Sale[]

  @@map("tipos_comprobante")
}

model Customer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentType   String   @map("document_type") @db.VarChar(20)
  documentNumber String   @map("document_number") @db.VarChar(30)
  name           String   @db.VarChar(180)
  address        String?  @db.VarChar(220)
  phone          String?  @db.VarChar(40)
  email          String?  @db.VarChar(160)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  sales          Sale[]

  @@unique([documentType, documentNumber])
  @@map("clientes")
}

model Sale {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serie           String          @unique @db.VarChar(40)
  voucherTypeId   String          @map("voucher_type_id") @db.Uuid
  paymentMethodId String          @map("payment_method_id") @db.Uuid
  clientId        String?         @map("client_id") @db.Uuid
  employeeId      String          @map("employee_id") @db.Uuid
  saleDate        DateTime        @map("sale_date") @db.Date
  saleTime        DateTime        @map("sale_time") @db.Time(6)
  subtotal        Decimal         @default(0) @db.Decimal(12, 2)
  discountPct     Decimal         @default(0) @map("discount_pct") @db.Decimal(5, 2)
  discountAmount  Decimal         @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total           Decimal         @default(0) @db.Decimal(12, 2)
  note            String?
  amountReceived  Decimal         @default(0) @map("amount_received") @db.Decimal(12, 2)
  changeAmount    Decimal         @default(0) @map("change_amount") @db.Decimal(12, 2)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  voucherType     VoucherType     @relation(fields: [voucherTypeId], references: [id])
  paymentMethod   PaymentMethod   @relation(fields: [paymentMethodId], references: [id])
  client          Customer?       @relation(fields: [clientId], references: [id])
  employee        Employee        @relation(fields: [employeeId], references: [id])
  details         SaleDetail[]

  @@map("ventas")
}

model SaleDetail {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId              String   @map("sale_id") @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  productNameSnapshot String   @map("product_name_snapshot") @db.VarChar(180)
  quantity            Decimal  @db.Decimal(12, 2)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal           Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  sale                Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id])

  @@map("detalle_venta")
}

model EmployeeAttendance {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  workDate     DateTime @map("work_date") @db.Date
  checkInTime  DateTime? @map("check_in_time") @db.Time(6)
  checkOutTime DateTime? @map("check_out_time") @db.Time(6)
  status       String   @db.VarChar(30)
  source       String   @default("manual") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workDate])
  @@map("asistencias_empleado")
}

model LossReason {
  id     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String          @unique @db.VarChar(100)
  active Boolean         @default(true)
  losses InventoryLoss[]

  @@map("motivos_perdida")
}

model InventoryLoss {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String     @map("product_id") @db.Uuid
  categoryId   String     @map("category_id") @db.Uuid
  supplierId   String?    @map("supplier_id") @db.Uuid
  employeeId   String?    @map("employee_id") @db.Uuid
  lossReasonId String     @map("loss_reason_id") @db.Uuid
  quantity     Decimal    @db.Decimal(12, 2)
  unitCost     Decimal    @map("unit_cost") @db.Decimal(12, 2)
  totalCost    Decimal    @map("total_cost") @db.Decimal(12, 2)
  lossDate     DateTime   @map("loss_date") @db.Date
  lossTime     DateTime   @map("loss_time") @db.Time(6)
  note         String?
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  product      Product    @relation(fields: [productId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  supplier     Supplier?  @relation(fields: [supplierId], references: [id])
  employee     Employee?  @relation(fields: [employeeId], references: [id])
  reason       LossReason @relation(fields: [lossReasonId], references: [id])

  @@map("perdidas_inventario")
}

model PayrollSlip {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slipNumber      String              @unique @map("slip_number") @db.VarChar(40)
  employeeId      String              @map("employee_id") @db.Uuid
  periodYear      Int                 @map("period_year")
  periodMonth     Int                 @map("period_month")
  issueDate       DateTime            @map("issue_date") @db.Date
  daysWorked      Int                 @default(0) @map("days_worked")
  dailyPay        Decimal             @default(0) @map("daily_pay") @db.Decimal(12, 2)
  subtotal        Decimal             @default(0) @db.Decimal(12, 2)
  discounts       Decimal             @default(0) @db.Decimal(12, 2)
  netTotal        Decimal             @default(0) @map("net_total") @db.Decimal(12, 2)
  createdByUserId String?             @map("created_by_user_id") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  employee        Employee            @relation(fields: [employeeId], references: [id])
  createdBy       User?               @relation(fields: [createdByUserId], references: [id])
  details         PayrollSlipDetail[]

  @@map("boletas_pago_empleado")
}

model PayrollSlipDetail {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollSlipId String      @map("payroll_slip_id") @db.Uuid
  workDate      DateTime    @map("work_date") @db.Date
  checkInTime   DateTime?   @map("check_in_time") @db.Time(6)
  checkOutTime  DateTime?   @map("check_out_time") @db.Time(6)
  amount        Decimal     @default(0) @db.Decimal(12, 2)
  payrollSlip   PayrollSlip @relation(fields: [payrollSlipId], references: [id], onDelete: Cascade)

  @@map("detalle_boleta_pago")
}

model InventoryMovement {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  movementType    String   @map("movement_type") @db.VarChar(30)
  referenceType   String?  @map("reference_type") @db.VarChar(40)
  referenceId     String?  @map("reference_id") @db.Uuid
  quantity        Decimal  @db.Decimal(12, 2)
  unitCost        Decimal? @map("unit_cost") @db.Decimal(12, 2)
  note            String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  product         Product  @relation(fields: [productId], references: [id])
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])

  @@map("movimientos_inventario")
}

model SupplierOrder {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId      String                @map("supplier_id") @db.Uuid
  orderNumber     String                @unique @map("order_number") @db.VarChar(40)
  status          String                @db.VarChar(30)
  orderDate       DateTime              @map("order_date") @db.Date
  expectedDate    DateTime?             @map("expected_date") @db.Date
  subtotal        Decimal               @default(0) @db.Decimal(12, 2)
  total           Decimal               @default(0) @db.Decimal(12, 2)
  note            String?
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @default(now()) @map("updated_at") @db.Timestamptz(6)
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  createdBy       User?                 @relation(fields: [createdByUserId], references: [id])
  details         SupplierOrderDetail[]

  @@map("pedidos_proveedor")
}

model SupplierOrderDetail {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierOrderId String        @map("supplier_order_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  quantity        Decimal       @db.Decimal(12, 2)
  unitCost        Decimal       @map("unit_cost") @db.Decimal(12, 2)
  lineTotal       Decimal       @map("line_total") @db.Decimal(12, 2)
  supplierOrder   SupplierOrder @relation(fields: [supplierOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@map("detalle_pedido_proveedor")
}
